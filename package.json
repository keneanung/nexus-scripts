{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/config-lerna-scopes": "^20.4.3",
    "@commitlint/cz-commitlint": "^20.5.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@swc/core": "^1.15.30",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-react-native-web": "^0.21.2",
    "commitizen": "^4.3.1",
    "core-js": "^3.49.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-webpack-plugin": "^6.0.0",
    "globals": "^17.5.0",
    "inquirer": "^13.4.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-mock": "^30.3.0",
    "jest-mock-extended": "^4.0.1",
    "lerna": "^9.0.7",
    "metro-react-native-babel-preset": "^0.77.0",
    "msw": "^2.13.4",
    "prettier": "^3.8.3",
    "regenerator-runtime": "^0.14.1",
    "undici": "^7.25.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "webpack": "^5.106.2",
    "webpack-auto-inject-version-next": "^1.2.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "scripts": {
    "test": "echo 'Workaround for npm rfc #575'; lerna exec --ignore @keneanung/iron-realms-nexus-typings --no-bail --no-progress --stream -- npx jest --testLocationInResults --collect-coverage --config jestconfig.js",
    "lint": "lerna exec --no-bail --no-progress --stream -- eslint . --ext .ts,.tsx",
    "webpack": "lerna exec --no-bail --no-progress --stream --ignore @keneanung/iron-realms-nexus-typings --ignore @keneanung/nexus-package-builder --ignore @keneanung/nexus-package-splitter --ignore @keneanung/nexus-simplified-scripting-converter -- webpack build --mode development",
    "webpackProd": "lerna exec --no-bail --no-progress --stream --ignore @keneanung/iron-realms-nexus-typings --ignore @keneanung/nexus-package-builder --ignore @keneanung/nexus-package-splitter --ignore @keneanung/nexus-simplified-scripting-converter -- webpack build --mode production",
    "build": "lerna run --no-bail --no-progress build",
    "nxs": "lerna run --no-bail --no-progress nxs",
    "nxsProd": "lerna run --no-bail --no-progress nxsProd",
    "commit": "git diff --cached --quiet && echo 'No staged files to commit.' || git-cz"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "overrides": {
    "lerna": "$lerna",
    "@commitlint/cz-commitlint": {
      "inquirer": "$inquirer"
    }
  }
}
